#!/usr/bin/env bash

PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-$(cd "$(dirname "$0")/.." && pwd)}"

# ── Installed version ─────────────────────────────────────────────────────────
INSTALLED_VERSION=$(python3 -c "
import json, sys
try:
    d = json.load(open('${PLUGIN_ROOT}/.claude-plugin/plugin.json'))
    print(d['version'])
except Exception:
    sys.exit(1)
" 2>/dev/null)

# ── Latest version from marketplace (silent failure, 3s timeout) ──────────────
LATEST_VERSION=$(curl -sf --max-time 3 \
  "https://raw.githubusercontent.com/saberapp/arsenal-marketplace/main/marketplace.json" \
  2>/dev/null | python3 -c "
import json, sys
try:
    d = json.load(sys.stdin)
    print(d['plugins'][0]['version'])
except Exception:
    sys.exit(1)
" 2>/dev/null)

# ── Context output ────────────────────────────────────────────────────────────
echo "# Saber Arsenal"
echo "Saber Arsenal is installed — GTM and RevOps skills for Claude Code, powered by the Saber CLI."
echo ""
echo "Available skills:"
echo "  - signal-discovery          — guided entry point: extract ICP then generate signals (start here)"
echo "  - extract-icp               — research a company domain and extract a structured ICP"
echo "  - generate-signals          — turn a structured ICP into 12–15 weighted research signals"
echo "  - create-company-signals    — activate company-level signal tracking"
echo "  - create-contact-signals    — activate contact-level signal tracking"
echo "  - build-account-list        — build a target account list and run signals"
echo "  - build-contact-list        — build a target contact list and run signals"
echo "  - enrich-contacts           — find email and phone for contacts via Apollo, Cognism, and others"
echo "  - research-account          — build a full account brief from signals, web search, and CRM data"
echo "  - qualify-inbound           — score an inbound lead using Saber signals"
echo "  - score-accounts            — rank a list of accounts by combined signal strength"
echo "  - write-outreach            — write personalised cold email and LinkedIn messages using signal data"
echo "  - build-sequence            — design a multi-step outreach sequence with signal-triggered variants"
echo "  - find-expansion-accounts   — identify existing customers showing upsell or cross-sell signals"
echo "  - manage-signals            — view, pause, resume, and trigger signal subscriptions"
echo "  - import-from-hubspot       — pull a HubSpot list into Saber as a target account or contact list"
echo "  - sync-to-hubspot           — push Saber signal results back to HubSpot as CRM properties"
echo ""
echo "Skills that use the Saber CLI will check if it is installed and offer a fallback path if not."

# ── Update notification ───────────────────────────────────────────────────────
if [ -n "$LATEST_VERSION" ] && [ -n "$INSTALLED_VERSION" ] && [ "$LATEST_VERSION" != "$INSTALLED_VERSION" ]; then
  echo ""
  echo "Update available: Saber Arsenal v${INSTALLED_VERSION} → v${LATEST_VERSION}"
  echo "Run /plugins update saber-arsenal to update."
fi

echo ""
echo "Use the Skill tool to invoke any Saber Arsenal skill."
