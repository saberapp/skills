#!/usr/bin/env bash

PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-$(cd "$(dirname "$0")/.." && pwd)}"

# ── Installed version ─────────────────────────────────────────────────────────
INSTALLED_VERSION=$(python3 -c "
import json, sys
try:
    d = json.load(open('${PLUGIN_ROOT}/.claude-plugin/plugin.json'))
    print(d['version'])
except Exception:
    sys.exit(1)
" 2>/dev/null)

# ── Latest version from marketplace (silent failure, 3s timeout) ──────────────
LATEST_VERSION=$(curl -sf --max-time 3 \
  "https://raw.githubusercontent.com/saberapp/saber-marketplace/main/.claude-plugin/marketplace.json" \
  2>/dev/null | python3 -c "
import json, sys
try:
    d = json.load(sys.stdin)
    print(d['plugins'][0]['version'])
except Exception:
    sys.exit(1)
" 2>/dev/null)

# ── Context output ────────────────────────────────────────────────────────────
echo "# Saber Skills"
echo "Saber Skills is installed — GTM and RevOps skills for Claude Code, by Saber."
echo ""
echo "Available skills:"
echo ""
echo "  Signal foundations"
echo "  - signal-discovery          — guided entry point: extract ICP then generate signals (start here)"
echo "  - extract-icp               — research a company domain and extract a structured ICP"
echo "  - generate-signals          — turn a structured ICP into 12–15 weighted research signals"
echo ""
echo "  Market and persona intelligence"
echo "  - market-map                — map a target market: segments, key players, entry points"
echo "  - persona-research          — deep profile of a buying persona: goals, challenges, buying behaviour"
echo "  - competitive-intel         — competitive landscape, battle cards, and positioning"
echo ""
echo "  List building"
echo "  - build-account-list        — build a target account list (Saber, Apollo, HubSpot, or manual)"
echo "  - build-contact-list        — build a target contact list (Saber, Apollo, LinkedIn, or manual)"
echo "  - enrich-contacts           — find email and phone via Apollo, Cognism, and others"
echo ""
echo "  Research and qualification"
echo "  - research-account          — build a full account brief from signals, web search, and CRM data"
echo "  - qualify-inbound           — score an inbound lead High / Medium / Low"
echo "  - score-accounts            — rank accounts by signal strength using a weighted scoring model"
echo ""
echo "  Signal activation (Saber CLI)"
echo "  - create-company-signals    — activate company-level signal tracking"
echo "  - create-contact-signals    — activate contact-level signal tracking"
echo "  - manage-signals            — view, pause, resume, and trigger signal subscriptions"
echo ""
echo "  Outreach"
echo "  - write-outreach            — personalised cold email and LinkedIn using signal data"
echo "  - build-sequence            — multi-step outreach sequence with signal-triggered variants"
echo "  - objection-handler         — build an objection library with response frameworks"
echo ""
echo "  Pipeline and deal management"
echo "  - deal-coaching             — analyse a deal and recommend next steps"
echo "  - pipeline-review           — audit pipeline health and surface at-risk deals"
echo "  - find-expansion-accounts   — identify customers showing upsell or cross-sell signals"
echo ""
echo "  CRM"
echo "  - import-from-hubspot       — pull a HubSpot list into Saber"
echo "  - sync-to-hubspot           — push signal results back to HubSpot as CRM properties"
echo ""
echo "Skills that use the Saber CLI will check if it is installed and offer a fallback path if not."

# ── Update notification ───────────────────────────────────────────────────────
if [ -n "$LATEST_VERSION" ] && [ -n "$INSTALLED_VERSION" ] && [ "$LATEST_VERSION" != "$INSTALLED_VERSION" ]; then
  echo ""
  echo "Update available: Saber Arsenal v${INSTALLED_VERSION} → v${LATEST_VERSION}"
  echo "Run /plugins update saber-skills to update."
fi

echo ""
echo "Use the Skill tool to invoke any Saber Arsenal skill."
